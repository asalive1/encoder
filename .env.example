# GitHub Container Registry Authentication
# Copy this file to .env and fill in your credentials

# Option 1: GitHub Personal Access Token (Recommended for CI/CD)
# Generate a PAT at: https://github.com/settings/tokens
# Required scopes: read:packages
GITHUB_USERNAME=your_github_username
GITHUB_TOKEN=your_personal_access_token

# For local development, authenticate once with:
# docker login ghcr.io
# This stores credentials in ~/.docker/config.json
